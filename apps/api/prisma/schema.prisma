generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  birthYear     Int?
  phone         String?
  emailVerified Boolean   @default(false)
  verifyCode    String?
  verifyCodeExpiresAt DateTime?
  resetCode     String?
  resetCodeExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  bloodType     String?
  allergies     String?
  medications   String?
  medicalNotes  String?
  qrCode        String   @unique @default(uuid())
  expoPushToken String?
  privacyShowName     Boolean @default(true)
  privacyShowPhone    Boolean @default(true)
  privacyShowMedical  Boolean @default(false)
  privacyShowContacts Boolean @default(true)
  privacyShowGps      Boolean @default(false)
  privacyShowNotes    Boolean @default(false)
  pushNotifyFriendsStart Boolean @default(true)
  pushNotifyFriendsEnd   Boolean @default(true)
  pushNotifyFriendsAlarm Boolean @default(true)
  tours              Tour[]
  friendsInitiated   Friend[]       @relation("FriendInitiator")
  friendsReceived    Friend[]       @relation("FriendReceiver")
  friendGroups       FriendGroup[]
  vehicles           Vehicle[]
  emergencyContacts  EmergencyContact[]
  organizedTourGroups TourGroup[]
  tourGroupInvites    TourGroupInvite[]
}

model EmergencyContact {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  phone     String
  relation  String?
  isPrimary Boolean  @default(false)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
}

model Tour {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?    @relation(fields: [vehicleId], references: [id])
  activity        ActivityType
  routeName       String?
  difficulty      String?
  persons         Int          @default(1)
  companions      Json?
  distanceKm      Float?
  elevationUp     Int?
  startedAt       DateTime?
  eta             DateTime?
  bufferMinutes   Int          @default(15)
  checkedOutAt    DateTime?
  startLat        Float?
  startLng        Float?
  lastLat         Float?
  lastLng         Float?
  locationUpdatedAt DateTime?
  gpxTrack        Json?
  overnightStops  Json?
  parkingLocation String?
  parkingLat      Float?
  parkingLng      Float?
  waypoints       Json?
  notes           String?
  groupId         String?
  group           TourGroup?   @relation(fields: [groupId], references: [id])
  status          TourStatus   @default(PLANNED)
  alarmStage      Int          @default(0)
  createdAt       DateTime     @default(now())
  alarmEvents     AlarmEvent[]
  locations       TourLocation[]
}

model TourLocation {
  id        String   @id @default(uuid())
  tourId    String
  tour      Tour     @relation(fields: [tourId], references: [id])
  lat       Float
  lng       Float
  ele       Float?
  accuracy  Float?
  timestamp DateTime @default(now())
}

enum TourStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ALARM
}

// A shared hike/tour that multiple people do together. Each participant
// still has their own Tour row (own ETA, own emergency contacts, own
// alarm escalation) — a missed return time must never be masked by other
// group members being fine. The group only ties the individual tours
// together for shared route context and mutual live visibility.
model TourGroup {
  id           String              @id @default(uuid())
  organizerId  String
  organizer    User                @relation(fields: [organizerId], references: [id])
  routeName    String?
  activity     ActivityType?
  createdAt    DateTime            @default(now())
  tours        Tour[]
  invites      TourGroupInvite[]
}

// Pending/accepted/declined invitations to join a TourGroup — separate
// from the Tour itself because someone can be invited before they've
// created their own individual Tour entry for the shared hike.
model TourGroupInvite {
  id          String    @id @default(uuid())
  groupId     String
  group       TourGroup @relation(fields: [groupId], references: [id])
  inviteeId   String
  invitee     User      @relation(fields: [inviteeId], references: [id])
  status      String    @default("PENDING") // PENDING | ACCEPTED | DECLINED
  createdAt   DateTime  @default(now())

  @@unique([groupId, inviteeId])
}

enum ActivityType {
  WANDERN
  BERGTOUR
  KLETTERN
  TRAILRUNNING
  MOUNTAINBIKE
  RADSPORT
  SKI_SNOWBOARD
  SKITOUR
  KLETTERSTEIG
  KANU_KAJAK
  PARAGLIDING
  ANDERE
}

model AlarmEvent {
  id          String   @id @default(uuid())
  tourId      String
  tour        Tour     @relation(fields: [tourId], references: [id])
  stage       Int
  triggeredAt DateTime @default(now())
  channel     String
  delivered   Boolean  @default(false)
}

model FriendGroup {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  color     String   @default("#2c694e")
  createdAt DateTime @default(now())
  friends   Friend[]
}

model Friend {
  id          String      @id @default(uuid())
  initiatorId String
  initiator   User        @relation("FriendInitiator", fields: [initiatorId], references: [id])
  receiverId  String
  receiver    User        @relation("FriendReceiver", fields: [receiverId], references: [id])
  groupId     String?
  group       FriendGroup? @relation(fields: [groupId], references: [id])
  status      String       @default("PENDING")
  createdAt   DateTime    @default(now())
}


model Vehicle {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  plate    String
  make     String?
  model    String?
  color    String?
  qrToken  String  @unique @default(uuid())
  tours    Tour[]
}