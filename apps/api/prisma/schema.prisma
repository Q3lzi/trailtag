generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  birthYear     Int?
  phone         String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())

  // Medizinische Infos
  bloodType     String?   // A+, A-, B+, B-, AB+, AB-, 0+, 0-
  allergies     String?
  medications   String?
  medicalNotes  String?

  tours              Tour[]
  vehicles           Vehicle[]
  emergencyContacts  EmergencyContact[]
}

model EmergencyContact {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  phone     String
  relation  String?  // z.B. "Partner", "Mutter", "Freund"
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Tour {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?    @relation(fields: [vehicleId], references: [id])

  activity        ActivityType
  routeName       String?
  difficulty      String?
  persons         Int          @default(1)

  distanceKm      Float?
  elevationUp     Int?

  startedAt       DateTime?
  eta             DateTime?
  bufferMinutes   Int          @default(15)
  checkedOutAt    DateTime?

  startLat        Float?
  startLng        Float?
  lastLat         Float?
  lastLng         Float?
  locationUpdatedAt DateTime?
  gpxTrack        Json?

  parkingLocation String?
  notes           String?

  status          TourStatus   @default(PLANNED)
  alarmStage      Int          @default(0)
  createdAt       DateTime     @default(now())

  alarmEvents     AlarmEvent[]
}

enum TourStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ALARM
}

enum ActivityType {
  WANDERN
  BERGTOUR
  KLETTERN
  TRAILRUNNING
  MOUNTAINBIKE
  RADSPORT
  SKI_SNOWBOARD
  SKITOUR
  KLETTERSTEIG
  KANU_KAJAK
  PARAGLIDING
  ANDERE
}

model AlarmEvent {
  id          String   @id @default(uuid())
  tourId      String
  tour        Tour     @relation(fields: [tourId], references: [id])
  stage       Int
  triggeredAt DateTime @default(now())
  channel     String
  delivered   Boolean  @default(false)
}

model Vehicle {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  plate    String
  make     String
  model    String
  color    String
  qrToken  String  @unique @default(uuid())
  tours    Tour[]
}