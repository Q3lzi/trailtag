{
  "expo": {
    "name": "Trailtag",
    "slug": "trailtag",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ch.trailtag.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Trailtag benötigt deinen Standort als Startpunkt der Tour.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Trailtag benötigt deinen Standort für die Sicherheitsfunktion."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a2e1a",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "ch.trailtag.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#1a2e1a"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Trailtag benötigt deinen Standort als Startpunkt der Tour."
        }
      ]
    ]
  }
}