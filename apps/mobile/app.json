{
  "expo": {
    "name": "Trailtag",
    "slug": "trailtag",
    "scheme": "trailtag",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ch.trailtag.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Trailtag ben\u00f6tigt deinen Standort als Startpunkt der Tour.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Trailtag ben\u00f6tigt deinen Standort f\u00fcr die Sicherheitsfunktion auch im Hintergrund.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a2e1a",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "ch.trailtag.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#1a2e1a"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Trailtag ben\u00f6tigt deinen Standort als Startpunkt der Tour.",
          "locationAlwaysAndWhenInUsePermission": "Trailtag ben\u00f6tigt deinen Standort f\u00fcr die Sicherheitsfunktion auch im Hintergrund.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a2e1a"
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": ""
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9a160091-e93c-4a3e-8a58-2c318e69f14d"
      }
    }
  }
}